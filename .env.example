# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Upstash Redis (Rate Limiting + Config Cache) ─────────────────────────────
# Create a free database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Clerk (Authentication) ───────────────────────────────────────────────────
# Create an app at: https://clerk.com → choose Next.js
# Copy from: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routing — keep these as-is
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Clerk webhook secret (for user sync)
# From: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Supabase (Database) ──────────────────────────────────────────────────────
# Create a project at: https://supabase.com
# Copy from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...     # Never expose this to the client

# ─── Razorpay (Payments — Phase 2) ────────────────────────────────────────────
# Create account at: https://razorpay.com → enable Subscriptions
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_WEBHOOK_SECRET=...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://scryveme.in

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=your-random-secret-here
